/**
 * Banner expiration.
 * The banner will stop showing on June 1, 2026 at 08:59 France time.
 */
$banner_expires_at = '2026-06-01 08:59:00';
$banner_timezone   = new DateTimeZone( 'Europe/Paris' );
$banner_now        = new DateTimeImmutable( 'now', $banner_timezone );
$banner_expiry     = new DateTimeImmutable( $banner_expires_at, $banner_timezone );

if ( $banner_now >= $banner_expiry ) {
	return;
}

$current_locale = function_exists( 'determine_locale' ) ? determine_locale() : get_locale();
$current_path   = isset( $_SERVER['REQUEST_URI'] ) ? sanitize_text_field( wp_unslash( $_SERVER['REQUEST_URI'] ) ) : '';

$is_french_version = strpos( $current_locale, 'fr' ) === 0 || strpos( $current_path, '/fr/' ) === 0;

$button_text = $is_french_version ? "J'en Profite" : 'REDEEM NOW';

$validity_text = $is_french_version
	? 'Offre valable jusqu’au 31 mai 2026'
	: 'Offer valid until May 31, 2026';

$banner_text = $is_french_version
	? 'Obtenez <strong>20 %</strong> de réduction en appliquant le code promo "<strong>HAWKSPINE20</strong>" lors du paiement de votre HawkSpine'
