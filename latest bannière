<script>
	document.addEventListener('DOMContentLoaded', function () {
		var banner = document.getElementById('hawkcell-promo-banner');

		if (!banner) {
			return;
		}

		/*
		 * Adjust this value if needed.
		 * When the user scrolls more than this number of pixels,
		 * the banner switches to the "scrolled" position.
		 */
		var scrollTrigger = 80;

		function updateBannerPosition() {
			if (window.scrollY > scrollTrigger) {
				banner.classList.add('hawkcell-promo-banner--scrolled');
			} else {
				banner.classList.remove('hawkcell-promo-banner--scrolled');
			}
		}

		updateBannerPosition();

		window.addEventListener('scroll', updateBannerPosition, { passive: true });
	});
</script>
