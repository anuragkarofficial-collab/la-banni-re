$banner_text_mobile = $is_french_version
	? '<strong>20 %</strong> de réduction avec le code "<strong>HAWKSPINE20</strong>" sur HawkSpine'
	: '<strong>20%</strong> off HawkSpine with code "<strong>HAWKSPINE20</strong>"';

/**
 * Button URL by language version.
 */
$button_url = $is_french_version
	? 'https://hawkspine.hawkcell.com/stripefr'
	: 'https://hawkspine.hawkcell.com/stripe';

$banner_classes = 'hawkcell-promo-banner' . ( $is_french_version ? ' hawkcell-promo-banner--fr' : '' );
